rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: episodes
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - soundcloudUrl: string (optional, valid URL)
    //   - pdfUrl: string (optional, valid URL)
    //   - updatedAt: timestamp (required)
    //   - updatedBy: string (required, UID)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "azzaspowerbi@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUrl(url) {
      return url is string && (url == "" || url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidEpisode(data) {
      return data.keys().hasAll(['title', 'updatedAt', 'updatedBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('soundcloudUrl' in data) || isValidUrl(data.soundcloudUrl)) &&
             (!('pdfUrl' in data) || isValidUrl(data.pdfUrl)) &&
             data.updatedAt is timestamp &&
             data.updatedBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /test/connection {
      allow read: if true;
    }

    match /episodes/{episodeId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidEpisode(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
