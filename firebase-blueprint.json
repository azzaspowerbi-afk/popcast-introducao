{
  "entities": {
    "episodes": {
      "title": "Episode",
      "description": "Podcast episode metadata and links",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Episode title" },
        "description": { "type": "string", "description": "Episode description" },
        "soundcloudUrl": { "type": "string", "description": "SoundCloud embed URL" },
        "pdfUrl": { "type": "string", "description": "Link to the PDF material" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "updatedBy": { "type": "string", "description": "UID of the admin who updated" }
      },
      "required": ["title", "updatedAt"]
    }
  },
  "firestore": {
    "episodes": {
      "schema": "episodes",
      "description": "Collection of podcast episodes"
    }
  }
}
